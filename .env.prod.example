# =============================================================================
# AWS EC2 production environment. Copy to /opt/uz-dropout/.env on the server
# before running docker-compose.prod.yml. Treat as secret — never commit.
# =============================================================================

# ----- Image tags written by the GitHub Actions deploy workflow -----
# GHCR_REPOSITORY is the `<owner>/<repo>` pair (lowercase).
GHCR_REPOSITORY=your-github-username/student-dropout-mlops
IMAGE_TAG=latest

# ----- API security (rotate before going live) -----
API_KEY=replace-with-output-of-openssl-rand-hex-32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ----- Default admin user -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ----- MLflow -----
MLFLOW_EXPERIMENT_NAME=student-dropout
MLFLOW_REGISTERED_MODEL_NAME=student-dropout-classifier

# ----- CORS (must include the public frontend origin) -----
# Replace 54.156.43.140 with your EC2 Elastic IP.
CORS_ALLOW_ORIGINS=http://54.156.43.140:4200

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Grafana -----
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace-with-a-strong-password
