.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Env files
.env
.env.local
*.env

# Data (DVC tracked)
data/raw/*
data/processed/*
data/reference/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reference/.gitkeep

# Models
models/champion/*
models/staging/*
!models/champion/.gitkeep
!models/staging/.gitkeep

# MLflow
mlruns/
mlartifacts/
mlflow.db

# Reports
reports/drift/*.html
reports/figures/*.png
reports/figures/*.html

# Frontend
node_modules/
frontend/dist/
frontend/.angular/

# Docker
docker-compose.override.yml

# Logs
logs/
*.log

# Terraform — state + tfvars carry secrets; never commit.
# Keep .tf sources but ignore generated state and user-specific vars.
*.tfstate
*.tfstate.*
*.tfvars
!infrastructure/terraform/terraform.tfvars.example
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log
