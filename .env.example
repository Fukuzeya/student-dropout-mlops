# =====================================================================
# Student Dropout MLOps — environment variables
# Copy this file to .env and fill in real values for local development.
# =====================================================================

# ----- API security -----
# Long random string used by service-to-service callers and the Angular app.
API_KEY=change-me-to-a-random-32-byte-hex
# HS256 secret for JWTs issued by /auth/token. Generate with `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-random-32-byte-hex
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ----- Default admin user (seeded at startup if no users exist) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ----- MLflow -----
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=student-dropout
MLFLOW_REGISTERED_MODEL_NAME=student-dropout-classifier

# ----- Postgres (MLflow backend store) -----
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# ----- API runtime -----
APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:4200,http://localhost:8080

# ----- Monitoring -----
DRIFT_REPORT_DIR=/app/reports/drift
REFERENCE_DATA_PATH=/app/data/reference/reference.parquet
